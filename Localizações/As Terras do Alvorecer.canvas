		{"id":"65671e31345688e8","type":"text","text":"Rio Dossel Eterno","x":3840,"y":1786,"width":250,"height":60,"color":"4"},
		{"id":"718882c947da23f9","type":"file","file":"Imagens/Mausoléus.jpg","x":5600,"y":1786,"width":953,"height":1191,"color":"4"},
